# Kompl v2 — environment variables
#
# Copy this file to `.env` (which is gitignored) and fill in real values.
# The real .env is loaded by docker compose at container start.
#
# Commit 2 only uses DB_PATH. The rest become live in commit 3+.

# ---- Storage ----

# SQLite database path INSIDE the app container. Must be on the named
# volume `kompl-data`, never a Windows host bind mount (see CLAUDE.md
# rule #1 "Storage substrate"). Architecture rule #1: exactly one open
# file handle at any instant.
DB_PATH=/data/db/kompl.db

# ---- LLM providers (live in commit 4) ----

# Gemini 2.5 Flash via the `google-genai` SDK (NOT the deprecated
# `google-generativeai` package).
# Get key at: https://aistudio.google.com/apikey
# Tier-1 limits (verified 2026-04-09): 1000 RPM / 1M TPM / 10K RPD.
# GEMINI_RPM default is 800 (80% of 1000). Adjust for your tier.
GEMINI_API_KEY=
GEMINI_RPM=800
GEMINI_INPUT_TOKEN_CAP=128000
GEMINI_DAILY_USD_CAP=5.00

# Anthropic Claude — alternative provider, same llm_client.py interface.
ANTHROPIC_API_KEY=

# ---- Ingestion (live in commit 3) ----

# Firecrawl v2 API key — https://docs.firecrawl.dev/
# Used by nlp-service/routers/conversion.py for URL → markdown conversion.
FIRECRAWL_API_KEY=

# ---- n8n (live in commit 3) ----
#
# Task runner timeout env vars — CRITICAL in n8n 2.x. The per-request
# default dropped from 300s to 60s with the 2.0 task runner changes. Both
# must be set explicitly.

N8N_RUNNERS_ENABLED=true
N8N_RUNNERS_TASK_TIMEOUT=300
N8N_RUNNERS_TASK_REQUEST_TIMEOUT=300

# Block Code-node access to $env. Forces use of n8n credentials files
# for API keys (which reference ${ENV_VAR} placeholders).
N8N_BLOCK_ENV_ACCESS_IN_NODE=true

# Binary data storage mode. `filesystem` stores uploaded files on the
# shared named volume so nlp-service can read them back.
N8N_DEFAULT_BINARY_DATA_MODE=filesystem

GENERIC_TIMEZONE=UTC

# ---- App (live in Part 2c-ii) ----

# Base URL for n8n webhooks, as seen from inside the app container.
# Used by confirm/route.ts and compile/retry/route.ts to trigger
# the session-compile workflow. Internal Docker network only.
N8N_WEBHOOK_URL=http://n8n:5678/webhook

# Base URL for this app container, used by /api/compile/run to call
# the individual compile endpoints as localhost HTTP calls.
APP_URL=http://app:3000
